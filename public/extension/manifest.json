{
  "name": "Ellexis Seat Watcher",
  "description": "Real-time class seat tracking for Ellexis.",
  "version": "1.0",
  "manifest_version": 3,

  "permissions": ["scripting", "tabs", "notifications"],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "background": {
    "service_worker": "bridge.js"
  },

  "content_scripts": [
    {
      "matches": ["https://portal.yourschool.edu/*"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
